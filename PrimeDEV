  // Always include current user first
  if(CUR_USER) {
    const already = online.find(o=>o.name===CUR_USER.name);
    if(!already) online.unshift({name:CUR_USER.name,role:'You',color:'#00b4ff'});
  }
  return online;
}

function refreshOnlineList(){
  const ol=document.getElementById('online-list'); if(!ol) return;
  const users=getOnlineUsers();
  ol.innerHTML=users.slice(0,8).map(u=>`
    <div class="ou">
      <div class="ou-dot" style="background:${u.color};box-shadow:0 0 6px ${u.color}"></div>
      <span class="ou-name">${u.name}</span>
      <span class="ou-badge">${u.role}</span>
    </div>`).join('');
  // Update channel online counts
  document.querySelectorAll('.rcnt').forEach(el=>{
    el.textContent=Math.max(1,Math.floor(users.length*Math.random()+1));
  });
  document.getElementById('conl').textContent=`&#x25CF; ${users.length} online`;
}

function initChat(){
  const area=document.getElementById('msgs'); if(!area) return;
  area.innerHTML='';
  refreshOnlineList();
  // Load stored messages for room
  const allMsgs=DB.msgs();
  const roomMsgs=allMsgs[CUR_ROOM]||[];
  if(roomMsgs.length===0){
    area.innerHTML=`<div class="msg-empty"><span style="font-size:2rem">&#x1F4AC;</span><div>No messages yet in #${CUR_ROOM}</div><div style="font-size:.72rem">Be the first to say something!</div></div>`;
  } else {
    roomMsgs.forEach(m=>appendMsg(m, m.email===CUR_USER?.email));
  }
}

function appendMsg(m, own){
  const area=document.getElementById('msgs');
  // Remove empty state if present
  const empty=area.querySelector('.msg-empty');
  if(empty) empty.remove();
  const d=document.createElement('div');
  d.className=`msg${own?' own':''}`;
  const ini=(m.name||'??').substring(0,2).toUpperCase();
  const colors=['#00b4ff','#00ffaa','#f0a500','#7850ff','#ff4466','#b44fff'];
  const color=colors[m.name.charCodeAt(0)%colors.length];
  d.innerHTML=`
    <div class="mav" style="background:linear-gradient(135deg,${color}22,${color}11);color:${color};border:1px solid ${color}33">${ini}</div>
    <div class="mb">
      <div class="mm">
        <span class="mn" style="color:${color}">${m.name}</span>
        <span class="mt">${m.time}</span>
      </div>
      <div class="mx">${escHtml(m.text)}</div>
    </div>`;
  area.appendChild(d);
  area.scrollTop=area.scrollHeight;
}

function escHtml(s){ const d=document.createElement('div'); d.textContent=s; return d.innerHTML; }

function sendMsg(){
  if(!CUR_USER){ toast('You must be logged in to chat','bad'); return; }
  const inp=document.getElementById('cin');
  const text=inp.value.trim(); if(!text) return;
  const now=new Date();
  const time=`${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
  const msg={name:CUR_USER.name,email:CUR_USER.email,text,time,room:CUR_ROOM,ts:Date.now()};
  // Save to localStorage
  const allMsgs=DB.msgs();
  if(!allMsgs[CUR_ROOM]) allMsgs[CUR_ROOM]=[];
  allMsgs[CUR_ROOM].push(msg);
  // Keep last 100 messages per room
  if(allMsgs[CUR_ROOM].length>100) allMsgs[CUR_ROOM]=allMsgs[CUR_ROOM].slice(-100);
  DB.saveMsgs(allMsgs);
  appendMsg(msg,true);
  inp.value='';
}

function swRoom(room, el){
  CUR_ROOM=room;
  document.querySelectorAll('.ri').forEach(r=>r.classList.remove('on')); el.classList.add('on');
  document.getElementById('crname').textContent='# '+room;
  document.getElementById('cin').placeholder=`Message #${room}...`;
  initChat();
}

// ================================================================
// JOIN TEAM
// ================================================================
function pSkill(el){
  document.querySelectorAll('.so').forEach(s=>s.classList.remove('on'));
  el.classList.add('on'); SEL_SKILL=el.dataset.skill;
}

function submitApp(){
  const nm=document.getElementById('j-nm').value.trim();
  const em=document.getElementById('j-em').value.trim();
  const exp=document.getElementById('j-exp').value;
  if(!nm||!validEmail(em)||!exp){ toast('Please fill all required fields','bad'); return; }
  // Save application
  const apps=DB.apps();
  const app={name:nm,email:em,skill:SEL_SKILL,exp,bio:document.getElementById('j-bio').value.trim(),date:new Date().toISOString()};
  apps.push(app); DB.saveApps(apps);
  // Start AI assessment
  startAIAssessment(nm,SEL_SKILL,exp);
}

// ================================================================
// AI ASSESSMENT ENGINE
// ================================================================
const AI = {
  name:'', skill:'', exp:'', answers:[], phase:'chosen_field', qIdx:0,
  chosenFieldQs: [],
  generalQs: [],
  allAnswers: [],
};

const FIELD_QUESTIONS = {
  'Frontend': [
    "What's the difference between CSS Flexbox and CSS Grid? When would you use each?",
    "Explain the concept of Virtual DOM in React and why it improves performance.",
    "What are Web Accessibility (a11y) best practices and why do they matter?",
    "How would you optimize a React application that is rendering slowly?",
    "Explain the difference between server-side rendering (SSR) and client-side rendering (CSR).",
  ],
  'Backend': [
    "Explain RESTful API principles and what makes a good REST API design.",
    "What is the difference between SQL and NoSQL databases? When do you choose each?",
    "How does authentication work with JWT tokens? Walk me through the flow.",
    "What are microservices and how do they differ from a monolithic architecture?",
    "Explain the concept of database indexing and when you would use it.",
  ],
  'AI/ML': [
    "What is the difference between supervised and unsupervised learning? Give examples.",
    "Explain overfitting and how you would prevent it in a machine learning model.",
    "What is gradient descent and how does it work in training neural networks?",
    "How does a Convolutional Neural Network (CNN) work and what is it best used for?",
    "What is transfer learning and why is it powerful in modern AI development?",
  ],
  'Design': [
    "What is the difference between UX and UI design? How do they work together?",
    "Explain the concept of design systems and why large companies invest in them.",
    "How do you approach user research before starting a design project?",
    "What is responsive design and how do you ensure your designs work across devices?",
    "Explain the importance of typography in user interface design.",
  ],
  'DevOps': [
    "Explain the concept of CI/CD pipelines and how they benefit development teams.",
    "What is containerization and how does Docker make it easier to deploy applications?",
    "Explain Kubernetes and how it helps manage containerized applications at scale.",
    "What is Infrastructure as Code (IaC) and what tools do you use for it?",
    "How would you monitor a production application and what metrics matter most?",
  ],
  'Mobile': [
    "What is the difference between native, hybrid, and cross-platform mobile development?",
    "Explain how React Native bridges JavaScript code to native mobile components.",
    "How do you handle offline functionality in a mobile application?",
    "What are the key differences in designing for iOS vs Android platforms?",
    "Explain mobile app performance optimization techniques you would use.",
  ],
};

const GENERAL_QUESTIONS = [
  "How comfortable are you with version control using Git? Explain branching strategies.",
  "Describe a technical project you're most proud of and what challenges you overcame.",
  "How do you approach learning a new technology or programming language?",
  "Explain the concept of agile methodology and how you've worked in a team environment.",
  "Where do you see yourself in 3 years, and how does joining Prime Dev Academy fit that vision?",
];

function startAIAssessment(name, skill, exp){
  AI.name=name; AI.skill=skill; AI.exp=exp; AI.answers=[]; AI.allAnswers=[];
  AI.chosenFieldQs=[...FIELD_QUESTIONS[skill]||FIELD_QUESTIONS['Frontend']];
  AI.generalQs=[...GENERAL_QUESTIONS];
  AI.phase='chosen_field'; AI.qIdx=0;
  // Show modal
  document.getElementById('ai-modal').classList.add('on');
  document.getElementById('ai-body').innerHTML='';
  document.getElementById('ai-step').textContent='Question 1 of 10';
  // Show success message first, then start questions
  aiMsg(`&#x1F389; <strong>Application Submission Successful!</strong><br/>Welcome to the future, <strong>${name}</strong>! Your application has been received.<br/><br/>I'm your AI Career Advisor. I'm now going to ask you <strong>10 questions</strong> — 5 about <strong>${skill}</strong> (your chosen field) and 5 general tech questions. Be honest and thorough. I'll assess your strengths and give you a professional recommendation. Ready? Let's begin!`);
  setTimeout(()=>askNext(), 1200);
}

function aiMsg(html, isTyping=false){
  const body=document.getElementById('ai-body');
  const d=document.createElement('div'); d.className='ai-msg';
  if(isTyping){
    d.innerHTML=`<div class="ai-av">&#x1F916;</div><div class="ai-bubble"><div class="typing"><div class="tdot"></div><div class="tdot"></div><div class="tdot"></div></div></div>`;
  } else {
    d.innerHTML=`<div class="ai-av">&#x1F916;</div><div class="ai-bubble">${html}</div>`;
  }
  body.appendChild(d);
  body.scrollTop=body.scrollHeight;
  return d;
}

function userMsg(text){
  const body=document.getElementById('ai-body');
  const d=document.createElement('div'); d.className='user-msg';
  d.textContent=text; body.appendChild(d);
  body.scrollTop=body.scrollHeight;
}

function askNext(){
  const totalQ = AI.chosenFieldQs.length + AI.generalQs.length; // 10 total
  const answered = AI.allAnswers.length;
  if(answered>=totalQ){ finishAssessment(); return; }
  // Update step counter
  document.getElementById('ai-step').textContent=`Question ${answered+1} of 10`;
  // Pick next question
  let q='';
  if(AI.phase==='chosen_field' && AI.chosenFieldQs.length>0){
    q=AI.chosenFieldQs.shift();
    if(AI.chosenFieldQs.length===0) AI.phase='general';
  } else if(AI.generalQs.length>0){
    q=AI.generalQs.shift();
  }
  // Show typing then question
  const typing=aiMsg('',true);
  setTimeout(()=>{
    typing.remove();
    const qNum=answered+1;
    const prefix = qNum<=5
      ? `<strong>&#x1F4CC; ${AI.skill} Question ${qNum}/5:</strong>`
      : `<strong>&#x1F310; General Question ${qNum-5}/5:</strong>`;
    aiMsg(`${prefix}<br/><br/>${q}`);
  },800);
}

function aiAnswer(){
  const inp=document.getElementById('ai-inp');
  const text=inp.value.trim(); if(!text) return;
  userMsg(text);
  AI.allAnswers.push({q:AI.allAnswers.length+1, answer:text});
  inp.value='';
  const answered=AI.allAnswers.length;
  const total=10;
  document.getElementById('ai-step').textContent=`Question ${Math.min(answered+1,total)} of ${total}`;
  if(answered>=total){ setTimeout(finishAssessment, 600); }
  else { setTimeout(askNext, 500); }
}

function finishAssessment(){
  document.getElementById('ai-inp-row').style.display='none';
  document.getElementById('ai-step').textContent='Analysis Complete';
  const typing=aiMsg('',true);
  setTimeout(()=>{
    typing.remove();
    aiMsg('&#x1F50D; <strong>Analysing your responses...</strong> Please hold on while I process your assessment.');
    setTimeout(()=>{
      const typing2=aiMsg('',true);
      setTimeout(()=>{
        typing2.remove();
        const result=analyseResults();
        showResult(result);
      },2000);
    },1200);
  },1000);
}

function analyseResults(){
  const skill=AI.skill; const exp=AI.exp; const name=AI.name;
  const answers=AI.allAnswers;
  // Analyse answer quality (length and depth as proxy)
  const avgLen=answers.reduce((s,a)=>s+a.answer.length,0)/answers.length;
  const depth = avgLen>150?'excellent':avgLen>80?'good':avgLen>40?'fair':'needs_development';
  // Field affinity scoring based on answers
  const fieldScores={
    'Frontend':0,'Backend':0,'AI/ML':0,'Design':0,'DevOps':0,'Mobile':0,'Full-Stack':0
  };
  const txt=answers.map(a=>a.answer.toLowerCase()).join(' ');
  if(txt.includes('react')||txt.includes('css')||txt.includes('ui')||txt.includes('html')||txt.includes('component')) fieldScores['Frontend']+=3;
  if(txt.includes('api')||txt.includes('database')||txt.includes('server')||txt.includes('node')||txt.includes('sql')) fieldScores['Backend']+=3;
  if(txt.includes('model')||txt.includes('data')||txt.includes('train')||txt.includes('neural')||txt.includes('machine')) fieldScores['AI/ML']+=3;
  if(txt.includes('design')||txt.includes('user')||txt.includes('ux')||txt.includes('figma')||txt.includes('prototype')) fieldScores['Design']+=3;
  if(txt.includes('docker')||txt.includes('deploy')||txt.includes('cloud')||txt.includes('pipeline')||txt.includes('ci')) fieldScores['DevOps']+=3;
  if(txt.includes('mobile')||txt.includes('ios')||txt.includes('android')||txt.includes('app')||txt.includes('native')) fieldScores['Mobile']+=3;
  if(txt.includes('full')||txt.includes('both')||txt.includes('frontend and backend')||txt.includes('everything')) fieldScores['Full-Stack']+=2;
  // Boost chosen field
  fieldScores[skill]+=4;
  // Find best field
  let bestField=skill, bestScore=fieldScores[skill];
  Object.entries(fieldScores).forEach(([f,s])=>{ if(s>bestScore){ bestField=f; bestScore=s; }});
  // Experience context
  const expCtx = exp.includes('Begin')?'beginner':exp.includes('Inter')?'intermediate':exp.includes('Adv')?'advanced':'expert';
  return {name,skill,bestField,depth,expCtx,avgLen:Math.round(avgLen)};
}

function showResult(r){
  const sameField=r.bestField===r.skill;
  const fieldIcons={'Frontend':'&#x1F3A8;','Backend':'&#x2699;&#xFE0F;','AI/ML':'&#x1F9E0;','Design':'&#x270F;&#xFE0F;','DevOps':'&#x1F527;','Mobile':'&#x1F4F1;','Full-Stack':'&#x26A1;'};
  const icon=fieldIcons[r.bestField]||'&#x26A1;';
  const depthMsg={excellent:'Your answers demonstrated strong depth and clarity. You clearly have solid understanding.',good:'Your responses showed good foundational knowledge with room to deepen your expertise.',fair:'Your answers show genuine potential. Focused learning will accelerate your growth significantly.',needs_development:'Your answers were brief — that\'s okay! Everyone starts somewhere. We\'ll help you grow.'};
  const pathMsg={beginner:'As a beginner, we recommend starting with our fundamentals track, building real projects early, and pairing with a senior mentor.',intermediate:'Your intermediate level is perfect for contributing to live projects immediately while sharpening advanced concepts.',advanced:'At your level, you\'re ready to lead projects, mentor others, and potentially contribute to core academy products.',expert:'As an expert, we\'d love to feature your work, involve you in architectural decisions, and explore partnership opportunities.'};
  const switchMsg = sameField ? `Your responses aligned well with your chosen field of <strong>${r.skill}</strong>.` : `Interestingly, while you applied for <strong>${r.skill}</strong>, your responses showed stronger affinity towards <strong>${r.bestField}</strong>. We recommend exploring this direction.`;
  const body=document.getElementById('ai-body');
  const div=document.createElement('div');
  div.className='ai-result';
  div.innerHTML=`
    <h3>&#x1F4CB; Assessment Report — ${r.name}</h3>
    <p><strong>Response Quality:</strong> ${depthMsg[r.depth]}</p>
    <p><strong>Field Analysis:</strong> ${switchMsg}</p>
    <p><strong>Experience Path:</strong> ${pathMsg[r.expCtx]}</p>
    <p style="margin-top:10px;color:var(--text);font-size:.84rem"><strong>&#x1F4A1; Final Recommendation:</strong> We believe you will thrive as a <strong style="color:var(--neon)">${r.bestField} Developer</strong> at Prime Developers Academy. Your profile shows ${r.depth==='excellent'?'exceptional':'promising'} potential. We will be in contact within 48 hours with your onboarding details.</p>
    <div class="best-field">${icon} Best Fit: ${r.bestField}</div>`;
  body.appendChild(div);
  body.scrollTop=body.scrollHeight;
  // Show close button
  const closeDiv=document.createElement('div');
  closeDiv.style.cssText='text-align:center;padding:8px 0;';
  closeDiv.innerHTML=`<button class="abtn" style="max-width:220px;margin:0 auto" onclick="closeAI()">&#x2713; Close Assessment</button>`;
  body.appendChild(closeDiv);
  body.scrollTop=body.scrollHeight;
}

function closeAI(){
  document.getElementById('ai-modal').classList.remove('on');
  document.getElementById('ai-inp-row').style.display='';
  document.getElementById('ai-body').innerHTML='';
  // Clear join form
  ['j-nm','j-em','j-bio'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('j-exp').selectedIndex=0;
  toast('Assessment complete! We\'ll be in touch &#x1F680;','ok');
}
</script>
