function initAuthCanvas(){
  const cv=document.getElementById('auth-cv'); if(!cv) return;
  const r=new THREE.WebGLRenderer({canvas:cv,antialias:true,alpha:true});
  r.setPixelRatio(Math.min(devicePixelRatio,2));
  const sc=new THREE.Scene(), cam=new THREE.PerspectiveCamera(60,innerWidth/innerHeight,.1,200);
  cam.position.z=30;
  function rsz(){ r.setSize(innerWidth,innerHeight); cam.aspect=innerWidth/innerHeight; cam.updateProjectionMatrix(); }
  rsz(); window.addEventListener('resize',rsz);
  const geo=new THREE.BufferGeometry();
  const cnt=700,pos=new Float32Array(cnt*3),col=new Float32Array(cnt*3);
  for(let i=0;i<cnt;i++){
    pos[i*3]=(Math.random()-.5)*90;pos[i*3+1]=(Math.random()-.5)*90;pos[i*3+2]=(Math.random()-.5)*90;
    const t=Math.random(); if(t<.5){col[i*3]=0;col[i*3+1]=.7;col[i*3+2]=1;}else{col[i*3]=.47;col[i*3+1]=.31;col[i*3+2]=1;}
  }
  geo.setAttribute('position',new THREE.BufferAttribute(pos,3)); geo.setAttribute('color',new THREE.BufferAttribute(col,3));
  const pts=new THREE.Points(geo,new THREE.PointsMaterial({size:.13,vertexColors:true,transparent:true,opacity:.7}));
  sc.add(pts);
  const shapes=[];
  for(let i=0;i<10;i++){
    const g=new THREE.IcosahedronGeometry(Math.random()*.9+.3,0);
    const m=new THREE.MeshBasicMaterial({color:i%2?0x00b4ff:0x7850ff,wireframe:true,transparent:true,opacity:.22});
    const mesh=new THREE.Mesh(g,m); mesh.position.set((Math.random()-.5)*35,(Math.random()-.5)*22,(Math.random()-.5)*12-5);
    mesh.userData={rx:Math.random()*.012,ry:Math.random()*.012}; sc.add(mesh); shapes.push(mesh);
  }
  let hmx=0,hmy=0;
  document.addEventListener('mousemove',e=>{hmx=(e.clientX/innerWidth-.5)*2;hmy=(e.clientY/innerHeight-.5)*2;});
  (function lp(){ requestAnimationFrame(lp); pts.rotation.y+=.0007;pts.rotation.x+=.0003;
    shapes.forEach(s=>{s.rotation.x+=s.userData.rx;s.rotation.y+=s.userData.ry;});
    cam.position.x+=(hmx*4-cam.position.x)*.03; cam.position.y+=(-hmy*3-cam.position.y)*.03;
    cam.lookAt(sc.position); r.render(sc,cam); })();
}

// ================================================================
// THREE.JS — HERO CANVAS
// ================================================================
function initHeroCanvas(){
  const cv=document.getElementById('hero-cv'); if(!cv) return;
  const r=new THREE.WebGLRenderer({canvas:cv,antialias:true,alpha:true});
  r.setPixelRatio(Math.min(devicePixelRatio,2));
  const sc=new THREE.Scene(),cam=new THREE.PerspectiveCamera(60,innerWidth/innerHeight,.1,300);
  cam.position.set(0,4,40);
  function rsz(){ const p=cv.parentElement; r.setSize(p.offsetWidth,p.offsetHeight); cam.aspect=p.offsetWidth/p.offsetHeight; cam.updateProjectionMatrix(); }
  rsz(); window.addEventListener('resize',rsz);
  const grid=new THREE.GridHelper(120,32,0x003355,0x001122); grid.position.y=-14; sc.add(grid);
  const geo=new THREE.BufferGeometry();
  const cnt=1400,pos=new Float32Array(cnt*3),col=new Float32Array(cnt*3);
  for(let i=0;i<cnt;i++){
    pos[i*3]=(Math.random()-.5)*130;pos[i*3+1]=(Math.random()-.5)*70;pos[i*3+2]=(Math.random()-.5)*90;
    const t=Math.random(); if(t<.33){col[i*3]=0;col[i*3+1]=.7;col[i*3+2]=1;}else if(t<.66){col[i*3]=.47;col[i*3+1]=.31;col[i*3+2]=1;}else{col[i*3]=.94;col[i*3+1]=.65;col[i*3+2]=0;}
  }
  geo.setAttribute('position',new THREE.BufferAttribute(pos,3)); geo.setAttribute('color',new THREE.BufferAttribute(col,3));
  const pts=new THREE.Points(geo,new THREE.PointsMaterial({size:.11,vertexColors:true,transparent:true,opacity:.6})); sc.add(pts);
  const orbs=[];
  [{r:2,c:0x0066cc,x:-16,y:5,z:-10},{r:1.4,c:0x5500cc,x:18,y:-2,z:-15},{r:2.4,c:0x0044aa,x:0,y:-9,z:-20},{r:1,c:0xcc8800,x:-8,y:11,z:-5}].forEach(d=>{
    const m=new THREE.Mesh(new THREE.SphereGeometry(d.r,14,14),new THREE.MeshBasicMaterial({color:d.c,wireframe:true,transparent:true,opacity:.13}));
    m.position.set(d.x,d.y,d.z); m.userData={baseY:d.y,spd:Math.random()*.3+.1,ph:Math.random()*Math.PI*2}; sc.add(m); orbs.push(m);
  });
  let hmx=0,hmy=0,t=0;
  document.addEventListener('mousemove',e=>{hmx=(e.clientX/innerWidth-.5);hmy=(e.clientY/innerHeight-.5);});
  (function lp(){ requestAnimationFrame(lp); t+=.008;
    pts.rotation.y+=.0003;pts.rotation.x+=.0001;
    grid.position.z=(t*2)%3.3-1.65;
    orbs.forEach(o=>{o.position.y=o.userData.baseY+Math.sin(t*o.userData.spd+o.userData.ph)*2;o.rotation.y+=.005;});
    cam.position.x+=(hmx*4-cam.position.x)*.02; cam.position.y+=(-hmy*2+4-cam.position.y)*.02;
    cam.lookAt(0,0,0); r.render(sc,cam); })();
}

