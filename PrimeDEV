<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<meta name="description" content="Prime Developers Academy — Building the Future with Code, AI & Innovation"/>
<title>Prime Developers Academy</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Orbitron:wght@400;600;700;800;900&family=Fira+Code:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#050a14;--surface:#0c1528;--surface2:#101e36;
  --border:rgba(0,180,255,.12);--neon:#00b4ff;--neon2:#7850ff;
  --gold:#f0a500;--green:#00ffaa;--red:#ff4466;--purple:#b44fff;
  --text:#e8f2ff;--muted:#5a7a9a;--glow:rgba(0,180,255,.3);--radius:16px;
  --fd:'Orbitron',sans-serif;--fb:'Space Grotesk',sans-serif;--fc:'Fira Code',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:var(--fb);background:var(--bg);color:var(--text);overflow-x:hidden;min-height:100vh;}
::selection{background:rgba(0,180,255,.3);color:#fff;}
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-track{background:var(--bg);}::-webkit-scrollbar-thumb{background:var(--neon);border-radius:2px;}
/* CURSOR */
#cur{position:fixed;width:10px;height:10px;background:var(--neon);border-radius:50%;pointer-events:none;z-index:99999;transform:translate(-50%,-50%);transition:width .2s,height .2s;mix-blend-mode:screen;left:-20px;top:-20px;}
#cur2{position:fixed;width:30px;height:30px;border:1.5px solid rgba(0,180,255,.45);border-radius:50%;pointer-events:none;z-index:99998;transform:translate(-50%,-50%);transition:all .12s ease;left:-20px;top:-20px;}
/* LOADER */
#loader{position:fixed;inset:0;z-index:99000;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity .8s ease;}
.ld-logo{font-family:var(--fd);font-weight:900;font-size:clamp(1rem,3vw,1.6rem);letter-spacing:3px;text-align:center;background:linear-gradient(135deg,var(--neon),var(--neon2),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:8px;animation:glowP 2s ease-in-out infinite;}
@keyframes glowP{0%,100%{filter:brightness(1);}50%{filter:brightness(1.6);}}
.ld-sub{font-family:var(--fc);font-size:.62rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:34px;}
.ld-ring{width:68px;height:68px;border:3px solid rgba(0,180,255,.07);border-top:3px solid var(--neon);border-right:3px solid var(--neon2);border-radius:50%;animation:spin 1s linear infinite;box-shadow:0 0 24px var(--glow);margin-bottom:22px;}
@keyframes spin{to{transform:rotate(360deg);}}
.ld-bar{width:210px;height:2px;background:rgba(255,255,255,.05);border-radius:1px;overflow:hidden;}
.ld-fill{height:100%;width:0;background:linear-gradient(90deg,var(--neon),var(--neon2));border-radius:1px;transition:width .3s ease;}
.ld-txt{font-family:var(--fc);font-size:.62rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:9px;}
/* SCREENS */
.scr{display:none;min-height:100vh;}
/* AUTH */
#scr-auth{position:relative;align-items:center;justify-content:center;min-height:100vh;overflow:hidden;}
#auth-cv{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;}
.auth-glow{position:absolute;inset:0;z-index:0;background:radial-gradient(ellipse at 25% 50%,rgba(0,180,255,.07),transparent 55%),radial-gradient(ellipse at 75% 30%,rgba(120,80,255,.07),transparent 55%);}
.auth-card{position:relative;z-index:10;background:rgba(8,15,30,.78);backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);border:1px solid rgba(0,180,255,.22);border-radius:24px;padding:clamp(30px,5vw,50px) clamp(26px,5vw,46px);width:100%;max-width:450px;box-shadow:0 0 80px rgba(0,180,255,.07),0 40px 80px rgba(0,0,0,.5);animation:cardF 6s ease-in-out infinite;}
@keyframes cardF{0%,100%{transform:translateY(0);}50%{transform:translateY(-8px);}}
.auth-brand{text-align:center;margin-bottom:26px;}
.auth-brand-logo{font-family:var(--fd);font-weight:900;font-size:.85rem;letter-spacing:2px;background:linear-gradient(135deg,var(--neon),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;display:block;margin-bottom:4px;}
.auth-brand-tag{font-family:var(--fc);font-size:.62rem;color:var(--muted);letter-spacing:1px;}
.auth-tabs{display:flex;gap:4px;background:rgba(255,255,255,.04);border-radius:11px;padding:4px;margin-bottom:26px;}
.atab{flex:1;padding:10px;text-align:center;border-radius:8px;font-size:.8rem;font-weight:700;cursor:pointer;color:var(--muted);transition:all .25s;border:none;background:transparent;font-family:var(--fb);}
.atab.on{background:linear-gradient(135deg,rgba(0,180,255,.18),rgba(120,80,255,.18));color:var(--neon);border:1px solid rgba(0,180,255,.25);}
.aform{display:none;}
.aform.on{display:block;animation:fadeUp .35s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
.fw{position:relative;margin-bottom:13px;}
.fico{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:.9rem;opacity:.4;pointer-events:none;z-index:1;}
.ainp{width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(0,180,255,.14);border-radius:11px;padding:12px 13px 12px 40px;color:var(--text);font-family:var(--fb);font-size:.86rem;outline:none;transition:border-color .2s,box-shadow .2s;}
.ainp:focus{border-color:var(--neon);box-shadow:0 0 16px rgba(0,180,255,.13);}
.ainp.err{border-color:var(--red);animation:shake .4s ease;}
@keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-5px);}75%{transform:translateX(5px);}}
.ainp::placeholder{color:var(--muted);}
.ferr{font-size:.68rem;color:var(--red);margin-top:3px;padding-left:3px;display:none;}
.ferr.on{display:block;}
.sbar{height:3px;background:rgba(255,255,255,.05);border-radius:2px;margin-top:5px;overflow:hidden;}
.sfill{height:100%;border-radius:2px;width:0;transition:width .3s,background .3s;}
.abtn{width:100%;padding:14px;border:none;border-radius:11px;margin-top:5px;background:linear-gradient(135deg,var(--neon),var(--neon2));color:#050a14;font-family:var(--fd);font-weight:700;font-size:.8rem;letter-spacing:1.5px;cursor:pointer;transition:transform .2s,box-shadow .3s;box-shadow:0 4px 22px rgba(0,180,255,.3);}
.abtn:hover{transform:translateY(-2px);box-shadow:0 8px 34px rgba(0,180,255,.45);}
/* MAIN */
#scr-main{display:none;}
#scr-main.on{display:flex;min-height:100vh;}
/* SIDEBAR */
.sb{position:fixed;top:0;left:0;bottom:0;width:66px;z-index:500;background:rgba(5,10,20,.97);backdrop-filter:blur(20px);border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;padding:16px 0;gap:5px;transition:width .3s cubic-bezier(.4,0,.2,1);overflow:hidden;}
.sb:hover{width:212px;}
.sb-logo{width:40px;height:40px;border-radius:11px;flex-shrink:0;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-weight:900;font-size:.95rem;color:#050a14;margin-bottom:16px;box-shadow:0 0 18px var(--glow);transition:transform .2s;}
.sb-logo:hover{transform:scale(1.06);}
.ni{width:calc(100% - 10px);display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:10px;cursor:pointer;transition:all .2s;color:var(--muted);font-weight:600;font-size:.78rem;white-space:nowrap;overflow:hidden;position:relative;border:1px solid transparent;}
.ni:hover,.ni.on{background:rgba(0,180,255,.09);color:var(--neon);border-color:rgba(0,180,255,.17);}
.ni.on::before{content:'';position:absolute;left:0;top:20%;bottom:20%;width:3px;background:var(--neon);border-radius:0 2px 2px 0;}
.ni-ico{font-size:1.05rem;flex-shrink:0;width:18px;text-align:center;}
.ni-lbl{opacity:0;transition:opacity .2s;white-space:nowrap;font-family:var(--fb);}
.sb:hover .ni-lbl{opacity:1;}
.sb-bot{margin-top:auto;width:calc(100% - 10px);}
.logout{width:100%;display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:10px;cursor:pointer;color:var(--muted);font-size:.78rem;font-weight:600;border:1px solid rgba(255,68,102,.12);transition:all .2s;background:transparent;font-family:var(--fb);white-space:nowrap;overflow:hidden;}
.logout:hover{color:var(--red);border-color:rgba(255,68,102,.4);background:rgba(255,68,102,.06);}
/* CONTENT */
.ct{flex:1;margin-left:66px;overflow-y:auto;overflow-x:hidden;}
/* SECTIONS */
.sec{display:none;min-height:100vh;animation:fadeUp .4s ease;}
.sec.on{display:block;}
/* HOME */
#s-home{position:relative;overflow:hidden;}
#hero-cv{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;}
.hw{position:relative;z-index:2;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:clamp(80px,10vw,120px) clamp(24px,5vw,60px) 60px;text-align:center;}
.h-eye{display:inline-flex;align-items:center;gap:7px;background:rgba(0,180,255,.06);border:1px solid rgba(0,180,255,.2);border-radius:50px;padding:7px 17px;font-size:.68rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--neon);margin-bottom:24px;font-family:var(--fc);animation:fadeUp .8s ease both;}
.blink{animation:blnk 1.4s infinite;}
@keyframes blnk{0%,100%{opacity:1;}50%{opacity:0;}}
.h1{font-family:var(--fd);font-size:clamp(2.2rem,6vw,5rem);font-weight:900;letter-spacing:-2px;line-height:1.06;margin-bottom:16px;animation:fadeUp .9s .1s ease both;}
.h1 .t1{display:block;color:var(--text);}
.h1 .t2{display:block;background:linear-gradient(135deg,var(--neon) 0%,var(--neon2) 50%,var(--gold) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.h-sub{font-size:clamp(.9rem,2vw,1.12rem);color:var(--muted);line-height:1.7;max-width:560px;margin:0 auto 38px;animation:fadeUp 1s .2s ease both;}
.h-sub span{color:var(--neon);font-weight:600;}
.h-btns{display:flex;gap:13px;justify-content:center;flex-wrap:wrap;animation:fadeUp 1s .3s ease both;}
.bp{display:inline-flex;align-items:center;gap:7px;background:linear-gradient(135deg,var(--neon),var(--neon2));color:#050a14;font-weight:700;font-size:.86rem;padding:13px 28px;border-radius:50px;border:none;cursor:pointer;transition:transform .2s,box-shadow .3s;box-shadow:0 4px 26px rgba(0,180,255,.35);font-family:var(--fb);}
.bp:hover{transform:translateY(-3px);box-shadow:0 10px 38px rgba(0,180,255,.45);}
.bo{display:inline-flex;align-items:center;gap:7px;background:transparent;color:var(--text);font-weight:600;font-size:.86rem;padding:12px 24px;border-radius:50px;border:1.5px solid rgba(0,180,255,.24);cursor:pointer;transition:all .2s;font-family:var(--fb);}
.bo:hover{border-color:var(--neon);color:var(--neon);background:rgba(0,180,255,.06);transform:translateY(-2px);}
.h-stats{display:flex;gap:34px;justify-content:center;flex-wrap:wrap;margin-top:60px;animation:fadeUp 1s .4s ease both;}
.st{text-align:center;}
.sn{font-family:var(--fd);font-weight:900;font-size:clamp(1.7rem,3vw,2.4rem);letter-spacing:-1px;background:linear-gradient(135deg,var(--neon),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.sl{font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:4px;}
.chip{position:absolute;font-family:var(--fc);font-size:.68rem;background:rgba(0,180,255,.06);border:1px solid rgba(0,180,255,.12);border-radius:7px;padding:4px 10px;color:var(--neon);pointer-events:none;z-index:1;animation:chipF 8s ease-in-out infinite;}
@keyframes chipF{0%,100%{transform:translateY(0) rotate(-1deg);opacity:.55;}50%{transform:translateY(-16px) rotate(1deg);opacity:1;}}
/* ABOUT */
#s-about{padding:clamp(60px,8vw,100px) clamp(24px,5vw,80px);}
.ag{display:grid;grid-template-columns:1fr 1fr;gap:clamp(34px,6vw,72px);align-items:center;max-width:1060px;margin:0 auto;}
.iw{display:flex;justify-content:center;}
.cf{position:relative;width:clamp(200px,26vw,290px);height:clamp(200px,26vw,290px);border-radius:26px;cursor:pointer;}
.cavi{width:100%;height:100%;border-radius:26px;background:linear-gradient(135deg,#0c1a30,#1a0c30);display:flex;align-items:center;justify-content:center;font-size:clamp(4.5rem,9vw,7rem);border:2px solid rgba(0,180,255,.2);box-shadow:0 0 50px rgba(0,180,255,.1);transition:box-shadow .4s,transform .4s;}
.cf:hover .cavi{box-shadow:0 0 90px rgba(0,180,255,.4),0 0 36px rgba(120,80,255,.3);transform:scale(1.02);}
.cr{position:absolute;inset:-9px;border-radius:34px;border:1.5px solid rgba(0,180,255,.11);animation:rr 9s linear infinite;}
.cr2{position:absolute;inset:-20px;border-radius:40px;border:1px dashed rgba(120,80,255,.07);animation:rr 14s linear infinite reverse;}
@keyframes rr{to{transform:rotate(360deg);}}
.cbadge{position:absolute;bottom:-13px;right:-13px;background:linear-gradient(135deg,var(--gold),#ff8c00);border-radius:11px;padding:7px 13px;font-family:var(--fd);font-size:.56rem;font-weight:700;color:#1a0800;letter-spacing:.5px;box-shadow:0 5px 18px rgba(240,165,0,.4);}
.se{font-family:var(--fc);font-size:.68rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--neon);margin-bottom:9px;}
.sh2{font-family:var(--fd);font-size:clamp(1.5rem,2.6vw,2.4rem);font-weight:800;letter-spacing:-1.5px;line-height:1.1;margin-bottom:16px;}
.sh2 em{font-style:normal;background:linear-gradient(135deg,var(--neon),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.cname{font-family:var(--fd);font-size:clamp(1.2rem,2vw,1.8rem);font-weight:800;letter-spacing:-.5px;margin-bottom:4px;color:var(--gold);}
.crole{font-size:.78rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:18px;font-family:var(--fc);}
.cbio{color:var(--muted);line-height:1.8;font-size:.88rem;margin-bottom:22px;}
.cbio strong{color:var(--text);}
.tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:22px;}
.tag{background:rgba(0,180,255,.07);border:1px solid rgba(0,180,255,.13);border-radius:50px;padding:4px 12px;font-size:.7rem;font-weight:600;color:var(--neon);transition:all .2s;}
.tag.p{color:var(--neon2);border-color:rgba(120,80,255,.2);background:rgba(120,80,255,.07);}
.tag.g{color:var(--gold);border-color:rgba(240,165,0,.2);background:rgba(240,165,0,.05);}
.cst{display:grid;grid-template-columns:repeat(3,1fr);gap:13px;}
.csc{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:13px;text-align:center;}
.csn{font-family:var(--fd);font-weight:800;font-size:1.25rem;color:var(--neon);}
.csl{font-size:.65rem;color:var(--muted);margin-top:3px;}
/* PROJECTS */
#s-proj{padding:clamp(60px,8vw,100px) clamp(24px,5vw,80px);background:linear-gradient(180deg,transparent,rgba(120,80,255,.024),transparent);}
.sh{text-align:center;margin-bottom:46px;}
.pg{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;max-width:1060px;margin:0 auto;}
.pc{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px;position:relative;overflow:hidden;transition:transform .3s,box-shadow .3s,border-color .3s;cursor:pointer;}
.pc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--neon),transparent);opacity:0;transition:opacity .3s;}
.pc:hover{transform:translateY(-5px);box-shadow:0 18px 46px rgba(0,0,0,.4),0 0 24px rgba(0,180,255,.1);border-color:rgba(0,180,255,.26);}
.pc:hover::before{opacity:1;}
.pl{display:inline-flex;align-items:center;gap:4px;font-size:.66rem;font-weight:700;padding:3px 9px;border-radius:50px;margin-bottom:13px;font-family:var(--fc);}
.lj{background:rgba(247,220,111,.1);color:#f7dc6f;border:1px solid rgba(247,220,111,.2);}
.lt{background:rgba(0,122,204,.1);color:#007acc;border:1px solid rgba(0,122,204,.2);}
.lp{background:rgba(53,114,165,.1);color:#5fa8d3;border:1px solid rgba(53,114,165,.24);}
.lh{background:rgba(227,76,38,.1);color:#e34c26;border:1px solid rgba(227,76,38,.2);}
.pn{font-family:var(--fd);font-size:.88rem;font-weight:700;margin-bottom:8px;}
.pd{color:var(--muted);font-size:.8rem;line-height:1.55;margin-bottom:16px;}
.pf{display:flex;align-items:center;justify-content:space-between;}
.ps{font-size:.7rem;color:var(--muted);}
.pb{display:inline-flex;align-items:center;gap:4px;background:rgba(0,180,255,.07);border:1px solid rgba(0,180,255,.17);border-radius:50px;padding:5px 13px;font-size:.7rem;font-weight:700;color:var(--neon);transition:all .2s;cursor:pointer;text-decoration:none;font-family:var(--fb);}
.pb:hover{background:rgba(0,180,255,.14);transform:translateY(-1px);}
.pload{text-align:center;padding:46px;color:var(--muted);font-family:var(--fc);}
.sspin{width:26px;height:26px;border:2px solid rgba(0,180,255,.1);border-top:2px solid var(--neon);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 11px;}
/* COMMUNITY CHAT */
#s-chat{padding:clamp(50px,7vw,80px) clamp(18px,4vw,60px);}
.chat-wrap{max-width:1060px;margin:0 auto;}
.chat-layout{display:grid;grid-template-columns:220px 1fr;gap:20px;height:600px;}
.crooms{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);display:flex;flex-direction:column;overflow:hidden;}
.cr-head{padding:13px 16px;border-bottom:1px solid var(--border);font-family:var(--fd);font-size:.68rem;font-weight:700;color:var(--neon);letter-spacing:1px;}
.rl{flex:1;overflow-y:auto;padding:6px;}
.ri{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;cursor:pointer;transition:all .2s;font-size:.8rem;font-weight:500;color:var(--muted);}
.ri:hover,.ri.on{background:rgba(0,180,255,.08);color:var(--neon);}
.rdot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.rcnt{margin-left:auto;font-size:.6rem;background:rgba(0,180,255,.13);color:var(--neon);border-radius:50px;padding:2px 7px;font-weight:700;}
/* online users sidebar */
.online-panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);display:flex;flex-direction:column;overflow:hidden;margin-top:12px;}
.op-head{padding:10px 14px;border-bottom:1px solid var(--border);font-family:var(--fd);font-size:.64rem;font-weight:700;color:var(--green);letter-spacing:1px;}
.op-list{padding:8px;display:flex;flex-direction:column;gap:5px;overflow-y:auto;max-height:160px;}
.ou{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:7px;font-size:.76rem;font-weight:600;}
.ou-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);flex-shrink:0;}
.ou-name{color:var(--text);}
.ou-badge{margin-left:auto;font-size:.6rem;color:var(--muted);font-family:var(--fc);}
/* main chat */
.cmain{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);display:flex;flex-direction:column;overflow:hidden;}
.chead{padding:13px 17px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.crname{font-family:var(--fd);font-size:.8rem;font-weight:700;}
.conl{font-size:.68rem;color:var(--green);}
.msgs{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px;}
.msgs::-webkit-scrollbar{width:3px;}
.msgs::-webkit-scrollbar-thumb{background:rgba(0,180,255,.1);border-radius:2px;}
.msg-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:var(--muted);font-family:var(--fc);font-size:.78rem;text-align:center;gap:8px;}
.msg{display:flex;gap:9px;animation:msgIn .3s ease;}
@keyframes msgIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.mav{width:32px;height:32px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;font-family:var(--fd);}
.mb{flex:1;}
.mm{display:flex;align-items:baseline;gap:6px;margin-bottom:3px;}
.mn{font-size:.78rem;font-weight:700;}
.mt{font-size:.6rem;color:var(--muted);font-family:var(--fc);}
.mx{font-size:.83rem;color:var(--muted);line-height:1.5;}
.msg.own{flex-direction:row-reverse;}
