function validateEmail(e){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e); }

function doLogin(){
  const email=document.getElementById('login-email').value.trim();
  const pass=document.getElementById('login-pass').value;
  let ok=true;
  if(!validateEmail(email)){ showErr('login-email','err-login-email'); ok=false; }
  if(pass.length<6){ showErr('login-pass','err-login-pass'); ok=false; }
  if(!ok) return;
  // Demo credentials
  const isDemo=(email==='demo@prime.dev'&&pass==='prime123');
  const saved=APP.users.find(u=>u.email===email&&u.password===pass);
  if(!isDemo&&!saved){ showErr('login-email','err-login-email'); document.getElementById('err-login-email').textContent='Invalid credentials'; return; }
  const user={email, name:saved?.name||'Developer', joined:new Date().toISOString()};
  APP.user=user;
  localStorage.setItem('pda_user',JSON.stringify(user));
  toast('Welcome back! 🚀','success');
  enterApp();
}

function doSignup(){
  const name=document.getElementById('sig-name').value.trim();
  const email=document.getElementById('sig-email').value.trim();
  const pass=document.getElementById('sig-pass').value;
  let ok=true;
  if(!name){ showErr('sig-name','err-sig-name'); ok=false; }
  if(!validateEmail(email)){ showErr('sig-email','err-sig-email'); ok=false; }
  if(pass.length<6){ showErr('sig-pass','err-sig-pass'); ok=false; }
  if(!ok) return;
  if(APP.users.find(u=>u.email===email)){ showErr('sig-email','err-sig-email'); document.getElementById('err-sig-email').textContent='Email already registered'; return; }
  const user={name,email,password:pass,joined:new Date().toISOString()};
  APP.users.push(user);
  localStorage.setItem('pda_users',JSON.stringify(APP.users));
  APP.user={name,email,joined:user.joined};
  localStorage.setItem('pda_user',JSON.stringify(APP.user));
  toast(`Welcome, ${name}! You're in the Academy 🎉`,'success');
  enterApp();
}

function showErr(inputId, errId){
  const inp=document.getElementById(inputId);
