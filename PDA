    {user:'Kev_Backend',color:'#7850ff',bg:'linear-gradient(135deg,#1a0033,#0d0022)',text:'Anyone working on microservices? Would love to collaborate on a Node.js project!',time:'09:48'},
  ],
  frontend:[
    {user:'Pavel_CEO',color:'#00b4ff',bg:'linear-gradient(135deg,#003355,#001133)',text:'Frontend devs — drop your latest projects here! Let\'s review and improve together. 💡',time:'10:00'},
    {user:'MiaNg',color:'#ff77cc',bg:'linear-gradient(135deg,#330022,#1a0011)',text:'Just finished the Three.js crash course. Building a 3D portfolio right now 🌟',time:'10:22'},
