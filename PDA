  ],
};
function initChat(){
  const msgs=SEED_MSGS[APP.currentRoom]||[];
  const area=document.getElementById('messages-area');
  area.innerHTML='';
  msgs.forEach(m=>addMsgToDOM(m,false));
}
function addMsgToDOM(m,isOwn){
  const area=document.getElementById('messages-area');
  const div=document.createElement('div');
  div.className=`msg${isOwn?' own':''}`;
  const initials=m.user.substring(0,2).toUpperCase();
  div.innerHTML=`
    <div class="msg-avatar" style="background:${m.bg||'var(--surface2)'}; color:${m.color||'var(--neon)'}; font-size:0.75rem; font-family:var(--font-display)">${initials}</div>
    <div class="msg-body">
      <div class="msg-meta">
        <span class="msg-name" style="color:${m.color||'var(--neon)'}">${m.user}</span>
        <span class="msg-time">${m.time}</span>
      </div>
      <div class="msg-text">${m.text}</div>
    </div>`;
  area.appendChild(div);
  area.scrollTop=area.scrollHeight;
}
function sendMsg(){
  const inp=document.getElementById('chat-input');
  const text=inp.value.trim();
  if(!text) return;
  const now=new Date();
  const time=`${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
  const userName=APP.user?.name||'You';
  addMsgToDOM({user:userName,color:'#00b4ff',bg:'linear-gradient(135deg,#003355,#001133)',text,time},true);
  inp.value='';
  // Simulate reply after 1-2s
  setTimeout(()=>{
    const replies=['Great point! 💡','I agree! Let\'s build it 🚀','That\'s exactly what we need here.','Awesome! Can you share the GitHub link?','🔥🔥🔥','Would love to collaborate on that!'];
    const bots=['Pavel_CEO','AlexDev','SarahAI','Kev_Backend'];
    const bot=bots[Math.floor(Math.random()*bots.length)];
    const reply=replies[Math.floor(Math.random()*replies.length)];
    addMsgToDOM({user:bot,color:'#00ffaa',bg:'linear-gradient(135deg,#003322,#001111)',text:reply,time});
  },1000+Math.random()*1000);
}
function switchRoom(room,el){
  APP.currentRoom=room;
  document.querySelectorAll('.room-item').forEach(r=>r.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('chat-room-name').textContent=`# ${room}`;
  const counts={'general':12,'frontend':8,'backend':5,'ai-ml':19,'projects':7};
  document.getElementById('chat-online').textContent=`● ${counts[room]||5} online`;
  document.getElementById('chat-input').placeholder=`Message #${room}...`;
  initChat();
}

