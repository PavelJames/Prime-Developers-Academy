// JOIN TEAM
// ============================================================
function pickSkill(el){
  document.querySelectorAll('.skill-opt').forEach(s=>s.classList.remove('sel'));
  el.classList.add('sel');
  APP.selectedSkill=el.dataset.skill;
}
function submitApplication(){
  const name=document.getElementById('j-name').value.trim();
  const email=document.getElementById('j-email').value.trim();
  const exp=document.getElementById('j-exp').value;
  const bio=document.getElementById('j-bio').value.trim();
  if(!name||!validateEmail(email)||!exp){ toast('Please fill all required fields','error'); return; }
  const app={name,email,skill:APP.selectedSkill,exp,bio,date:new Date().toISOString()};
  APP.applications.push(app);
  localStorage.setItem('pda_apps',JSON.stringify(APP.applications));
  document.getElementById('join-success').classList.add('show');
  toast('Application submitted! 🚀','success');
  // Clear form
  ['j-name','j-email','j-bio'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('j-exp').selectedIndex=0;
}

// ============================================================
// CEO IMAGE HOVER EFFECT
// ============================================================
document.addEventListener('DOMContentLoaded',()=>{
  const frame=document.getElementById('ceo-frame');
  if(frame){
    frame.addEventListener('mousemove',e=>{
      const rect=frame.getBoundingClientRect();
      const x=(e.clientX-rect.left)/rect.width-0.5;
      const y=(e.clientY-rect.top)/rect.height-0.5;
      frame.style.transform=`perspective(600px) rotateY(${x*20}deg) rotateX(${-y*20}deg)`;
    });
    frame.addEventListener('mouseleave',()=>{ frame.style.transform=''; });
  }
});

// ============================================================
// KEYBOARD SHORTCUT
// ============================================================
document.addEventListener('keydown',e=>{
  if(e.key==='Escape') document.querySelectorAll('.section').forEach(s=>{ if(s.id!=='sec-home') s.classList.remove('active'); });
});
