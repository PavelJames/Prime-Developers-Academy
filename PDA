// THREE.JS — HERO CANVAS
// ============================================================
let heroScene, heroRenderer, heroCamera, heroParticles, heroLines=[], heroTime=0;
function initHeroScene(){
  const canvas = document.getElementById('hero-canvas');
  if(!canvas||heroRenderer) return;
  heroRenderer = new THREE.WebGLRenderer({canvas,antialias:true,alpha:true});
  heroRenderer.setPixelRatio(Math.min(devicePixelRatio,2));
  heroScene = new THREE.Scene();
  heroCamera = new THREE.PerspectiveCamera(60, canvas.parentElement.offsetWidth/canvas.parentElement.offsetHeight, 0.1, 300);
  heroCamera.position.z = 40;

  function resize(){
    const w=canvas.parentElement.offsetWidth, h=canvas.parentElement.offsetHeight;
    heroRenderer.setSize(w,h);
    heroCamera.aspect=w/h;
    heroCamera.updateProjectionMatrix();
  }
  resize(); window.addEventListener('resize',resize);

  // Animated grid plane
  const gridHelper = new THREE.GridHelper(100,30,0x003355,0x001122);
  gridHelper.position.y=-12;
  heroScene.add(gridHelper);

  // Large particle field
  const geo=new THREE.BufferGeometry();
  const cnt=1200; const pos=new Float32Array(cnt*3); const col=new Float32Array(cnt*3);
  for(let i=0;i<cnt;i++){
    pos[i*3]=(Math.random()-0.5)*120;
    pos[i*3+1]=(Math.random()-0.5)*60;
    pos[i*3+2]=(Math.random()-0.5)*80;
    const t=Math.random();
    if(t<0.33){col[i*3]=0;col[i*3+1]=0.7;col[i*3+2]=1;}
    else if(t<0.66){col[i*3]=0.47;col[i*3+1]=0.31;col[i*3+2]=1;}
    else{col[i*3]=0.94;col[i*3+1]=0.65;col[i*3+2]=0;}
  }
  geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
  geo.setAttribute('color',new THREE.BufferAttribute(col,3));
  heroParticles=new THREE.Points(geo,new THREE.PointsMaterial({size:0.12,vertexColors:true,transparent:true,opacity:0.6}));
  heroScene.add(heroParticles);

  // Floating orbs (spheres)
  const orbs=[];
  const orbData=[
    {r:2,c:0x0066cc,x:-15,y:5,z:-10},{r:1.5,c:0x5500cc,x:18,y:-3,z:-15},
    {r:2.5,c:0x0044aa,x:0,y:-8,z:-20},{r:1,c:0xcc8800,x:-8,y:10,z:-5},
    {r:1.8,c:0x3300cc,x:20,y:8,z:-12},
  ];
  orbData.forEach(d=>{
    const m=new THREE.Mesh(
      new THREE.SphereGeometry(d.r,16,16),
      new THREE.MeshBasicMaterial({color:d.c,wireframe:true,transparent:true,opacity:0.15})
    );
    m.position.set(d.x,d.y,d.z);
    m.userData={baseY:d.y,speed:Math.random()*0.3+0.1,phase:Math.random()*Math.PI*2};
    heroScene.add(m); orbs.push(m);
  });

  let hmx=0,hmy=0;
  document.addEventListener('mousemove',e=>{hmx=(e.clientX/innerWidth-0.5);hmy=(e.clientY/innerHeight-0.5);});

  (function animate(){
    requestAnimationFrame(animate);
    heroTime+=0.008;
    heroParticles.rotation.y+=0.0003; heroParticles.rotation.x+=0.0001;
    gridHelper.position.z=(heroTime*2)%3.33-1.67;
    orbs.forEach(o=>{ o.position.y=o.userData.baseY+Math.sin(heroTime*o.userData.speed+o.userData.phase)*2; o.rotation.y+=0.005; });
    heroCamera.position.x+=(hmx*4-heroCamera.position.x)*0.02;
    heroCamera.position.y+=(-hmy*2-heroCamera.position.y)*0.02;
    heroCamera.lookAt(heroScene.position);
    heroRenderer.render(heroScene,heroCamera);
  })();
}

