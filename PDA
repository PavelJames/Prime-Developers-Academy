
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta name="description" content="Prime Developers Academy — Building the Future with Code, AI & Innovation"/>
<meta name="theme-color" content="#050a14"/>
<title>Prime Developers Academy</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Orbitron:wght@400;600;700;800;900&family=Fira+Code:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
/* ============================================================
   CSS VARIABLES & RESET
============================================================ */
:root {
  --bg: #050a14;
  --bg2: #080f1e;
  --surface: #0c1528;
  --surface2: #101e36;
  --border: rgba(0,180,255,0.12);
  --border2: rgba(120,80,255,0.15);
  --neon: #00b4ff;
  --neon2: #7850ff;
  --gold: #f0a500;
  --green: #00ffaa;
  --red: #ff4466;
  --text: #e8f2ff;
  --muted: #5a7a9a;
  --glow: rgba(0,180,255,0.3);
  --glow2: rgba(120,80,255,0.25);
  --radius: 16px;
  --font-display: 'Orbitron', sans-serif;
  --font-body: 'Space Grotesk', sans-serif;
  --font-code: 'Fira Code', monospace;
}
*,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  min-height: 100vh;
  cursor: none;
}
::selection { background: rgba(0,180,255,0.3); color: #fff; }
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--neon); border-radius: 2px; }

/* ============================================================
   CUSTOM CURSOR
============================================================ */
#cursor { position: fixed; width: 10px; height: 10px; background: var(--neon); border-radius: 50%; pointer-events: none; z-index: 99999; transform: translate(-50%,-50%); transition: transform 0.1s, width 0.2s, height 0.2s, background 0.2s; mix-blend-mode: screen; }
#cursor-trail { position: fixed; width: 32px; height: 32px; border: 1.5px solid rgba(0,180,255,0.5); border-radius: 50%; pointer-events: none; z-index: 99998; transform: translate(-50%,-50%); transition: all 0.15s ease; }
body * { cursor: none !important; }

/* ============================================================
   LOADER
============================================================ */
#loader {
  position: fixed; inset: 0; z-index: 10000;
  background: var(--bg);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  transition: opacity 0.8s ease;
}
.loader-logo {
  font-family: var(--font-display);
  font-size: clamp(1.2rem, 3vw, 1.8rem);
  font-weight: 900;
  letter-spacing: 2px;
  background: linear-gradient(135deg, var(--neon), var(--neon2), var(--gold));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  margin-bottom: 32px;
  animation: logoPulse 2s ease-in-out infinite;
}
@keyframes logoPulse { 0%,100%{filter:brightness(1);} 50%{filter:brightness(1.5);} }
.loader-ring {
  width: 80px; height: 80px;
  border: 3px solid rgba(0,180,255,0.1);
  border-top: 3px solid var(--neon);
  border-right: 3px solid var(--neon2);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  box-shadow: 0 0 30px var(--glow);
  margin-bottom: 24px;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loader-bar-track { width: 200px; height: 2px; background: rgba(255,255,255,0.06); border-radius: 1px; overflow: hidden; }
.loader-bar-fill { height: 100%; background: linear-gradient(90deg, var(--neon), var(--neon2)); border-radius: 1px; animation: loadFill 2s ease forwards; }
@keyframes loadFill { from{width:0;} to{width:100%;} }
.loader-text { font-size: 0.72rem; color: var(--muted); letter-spacing: 3px; text-transform: uppercase; margin-top: 12px; font-family: var(--font-code); }

/* ============================================================
   PAGE SYSTEM
============================================================ */
.page { display: none; min-height: 100vh; }
.page.active { display: block; animation: pageIn 0.5s ease; }
@keyframes pageIn { from{opacity:0;transform:translateY(16px);} to{opacity:1;transform:translateY(0);} }

/* ============================================================
   3D CANVAS
============================================================ */
#hero-canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
#login-canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }

/* ============================================================
   LOGIN / SIGNUP PAGE
============================================================ */
#page-auth {
  position: relative; min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; padding: 24px;
}
.auth-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 30% 50%, rgba(0,180,255,0.08) 0%, transparent 60%),
              radial-gradient(ellipse at 70% 30%, rgba(120,80,255,0.08) 0%, transparent 60%);
}
.auth-card {
  position: relative; z-index: 10;
  background: rgba(8,15,30,0.7);
  backdrop-filter: blur(24px);
  border: 1px solid rgba(0,180,255,0.2);
  border-radius: 24px;
  padding: clamp(32px,5vw,56px) clamp(28px,5vw,52px);
  width: 100%; max-width: 480px;
  box-shadow: 0 0 80px rgba(0,180,255,0.08), 0 40px 80px rgba(0,0,0,0.5);
  animation: cardFloat 6s ease-in-out infinite;
}
@keyframes cardFloat { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-8px);} }
.auth-logo {
  font-family: var(--font-display);
  font-weight: 900; font-size: 1rem;
  letter-spacing: 2px; text-align: center; margin-bottom: 4px;
  background: linear-gradient(135deg, var(--neon), var(--neon2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.auth-tagline { text-align: center; color: var(--muted); font-size: 0.75rem; letter-spacing: 1px; margin-bottom: 32px; }
.auth-tabs { display: flex; gap: 4px; background: rgba(255,255,255,0.04); border-radius: 12px; padding: 4px; margin-bottom: 32px; }
.auth-tab {
  flex: 1; padding: 10px; text-align: center; border-radius: 9px;
  font-size: 0.82rem; font-weight: 700; cursor: pointer;
  color: var(--muted); transition: all 0.2s; border: none; background: transparent;
  font-family: var(--font-body);
}
.auth-tab.active { background: linear-gradient(135deg, rgba(0,180,255,0.2), rgba(120,80,255,0.2)); color: var(--neon); border: 1px solid rgba(0,180,255,0.25); }
.field-wrap { position: relative; margin-bottom: 16px; }
.field-icon { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); font-size: 1rem; opacity: 0.5; pointer-events: none; z-index: 1; }
.auth-input {
  width: 100%; background: rgba(255,255,255,0.04);
  border: 1px solid rgba(0,180,255,0.15);
  border-radius: 12px; padding: 14px 16px 14px 44px;
  color: var(--text); font-family: var(--font-body); font-size: 0.9rem;
  transition: border-color 0.2s, box-shadow 0.2s; outline: none;
}
.auth-input:focus { border-color: var(--neon); box-shadow: 0 0 20px rgba(0,180,255,0.15); }
.auth-input.error { border-color: var(--red); animation: shake 0.4s ease; }
@keyframes shake { 0%,100%{transform:translateX(0);} 25%{transform:translateX(-6px);} 75%{transform:translateX(6px);} }
.auth-input::placeholder { color: var(--muted); }
.field-error { font-size: 0.72rem; color: var(--red); margin-top: 4px; padding-left: 4px; display: none; }
.field-error.show { display: block; animation: fadeIn 0.2s ease; }
.strength-bar { height: 3px; border-radius: 2px; margin-top: 6px; background: rgba(255,255,255,0.06); overflow: hidden; }
.strength-fill { height: 100%; border-radius: 2px; transition: width 0.3s, background 0.3s; width: 0; }
.auth-btn {
  width: 100%; padding: 15px; border: none; border-radius: 12px;
  background: linear-gradient(135deg, var(--neon), var(--neon2));
  color: #050a14; font-family: var(--font-display); font-weight: 700;
  font-size: 0.85rem; letter-spacing: 1px; cursor: pointer;
  transition: transform 0.2s, box-shadow 0.3s; margin-top: 8px;
  box-shadow: 0 4px 24px rgba(0,180,255,0.3);
  position: relative; overflow: hidden;
}
.auth-btn::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent); opacity: 0; transition: opacity 0.2s; }
.auth-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 36px rgba(0,180,255,0.4); }
.auth-btn:hover::before { opacity: 1; }
.auth-divider { text-align: center; color: var(--muted); font-size: 0.75rem; margin: 20px 0; position: relative; }
.auth-divider::before,.auth-divider::after { content: ''; position: absolute; top: 50%; width: 40%; height: 1px; background: rgba(255,255,255,0.08); }
.auth-divider::before { left: 0; } .auth-divider::after { right: 0; }
.demo-note { text-align: center; font-size: 0.72rem; color: var(--muted); font-family: var(--font-code); margin-top: 16px; }
.demo-note span { color: var(--neon); }

/* ============================================================
   MAIN LAYOUT — SIDEBAR + CONTENT
============================================================ */
#page-main { display: none; }
#page-main.active { display: flex; min-height: 100vh; }

.sidebar {
  position: fixed; top: 0; left: 0; bottom: 0;
  width: 72px; z-index: 500;
  background: rgba(5,10,20,0.95);
  backdrop-filter: blur(20px);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column; align-items: center;
  padding: 20px 0; gap: 8px;
  transition: width 0.3s cubic-bezier(0.4,0,0.2,1);
}
.sidebar:hover { width: 220px; }
.sidebar-logo {
  width: 44px; height: 44px;
  background: linear-gradient(135deg, var(--neon), var(--neon2));
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display); font-weight: 900; font-size: 1rem;
  color: #050a14; margin-bottom: 20px; flex-shrink: 0;
  box-shadow: 0 0 20px var(--glow);
  transition: transform 0.2s;
}
.sidebar-logo:hover { transform: scale(1.08); }
.nav-item {
  width: calc(100% - 16px);
  display: flex; align-items: center; gap: 14px;
  padding: 12px 14px; border-radius: 12px;
  cursor: pointer; transition: all 0.2s;
  color: var(--muted); font-weight: 600; font-size: 0.82rem;
  white-space: nowrap; overflow: hidden;
  position: relative;
}
.nav-item:hover,.nav-item.active {
  background: rgba(0,180,255,0.1);
  color: var(--neon);
  border: 1px solid rgba(0,180,255,0.2);
}
.nav-item.active::before {
  content: ''; position: absolute; left: 0; top: 20%; bottom: 20%;
  width: 3px; background: var(--neon); border-radius: 0 2px 2px 0;
}
.nav-icon { font-size: 1.15rem; flex-shrink: 0; width: 20px; text-align: center; }
.nav-label { opacity: 0; transition: opacity 0.2s; white-space: nowrap; }
.sidebar:hover .nav-label { opacity: 1; }
.sidebar-bottom { margin-top: auto; width: calc(100% - 16px); }
.logout-btn {
  width: 100%; display: flex; align-items: center; gap: 14px;
  padding: 12px 14px; border-radius: 12px; cursor: pointer;
  color: var(--muted); font-size: 0.82rem; font-weight: 600;
  border: 1px solid rgba(255,68,102,0.15); transition: all 0.2s;
  background: transparent; font-family: var(--font-body);
  white-space: nowrap; overflow: hidden;
}
.logout-btn:hover { color: var(--red); border-color: rgba(255,68,102,0.4); background: rgba(255,68,102,0.06); }

/* ============================================================
   MAIN CONTENT AREA
============================================================ */
.main-content {
  flex: 1; margin-left: 72px;
  transition: margin-left 0.3s;
  overflow-y: auto; overflow-x: hidden;
}

/* ============================================================
   SECTION CONTAINERS
============================================================ */
.section { display: none; min-height: 100vh; }
.section.active { display: block; animation: pageIn 0.4s ease; }

/* ============================================================
   HERO SECTION
============================================================ */
#sec-home {
  position: relative; min-height: 100vh;
  display: flex; flex-direction: column;
  overflow: hidden;
}
.hero-wrap {
  position: relative; z-index: 2;
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: clamp(80px,10vw,120px) clamp(24px,5vw,60px) 60px;
  text-align: center;
}
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(0,180,255,0.06); border: 1px solid rgba(0,180,255,0.2);
  border-radius: 50px; padding: 8px 20px;
  font-size: 0.72rem; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--neon);
  margin-bottom: 28px; animation: fadeUp 0.8s ease both;
  font-family: var(--font-code);
}
.blink { animation: blinkAnim 1.5s infinite; }
@keyframes blinkAnim { 0%,100%{opacity:1;} 50%{opacity:0;} }
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.4rem,6vw,5.5rem);
  font-weight: 900; letter-spacing: -2px; line-height: 1.05;
  margin-bottom: 20px;
  animation: fadeUp 0.9s 0.1s ease both;
}
.hero-title .line1 { display: block; color: var(--text); }
.hero-title .line2 {
  display: block;
  background: linear-gradient(135deg, var(--neon) 0%, var(--neon2) 50%, var(--gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.hero-sub {
  font-size: clamp(1rem,2vw,1.2rem); color: var(--muted); line-height: 1.7;
  max-width: 620px; margin: 0 auto 44px;
  animation: fadeUp 1s 0.2s ease both;
}
.hero-sub span { color: var(--neon); font-weight: 600; }
.hero-btns {
  display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
  animation: fadeUp 1s 0.3s ease both;
}
.btn-primary {
  display: inline-flex; align-items: center; gap: 10px;
  background: linear-gradient(135deg, var(--neon), var(--neon2));
  color: #050a14; font-weight: 700; font-size: 0.9rem;
  padding: 15px 32px; border-radius: 50px; border: none; cursor: pointer;
  transition: transform 0.2s, box-shadow 0.3s;
  box-shadow: 0 4px 28px rgba(0,180,255,0.35);
  font-family: var(--font-body); letter-spacing: 0.3px;
  position: relative; overflow: hidden;
}
.btn-primary::before { content:''; position:absolute; inset:0; background:linear-gradient(135deg,rgba(255,255,255,0.2),transparent); opacity:0; transition:opacity 0.2s; }
.btn-primary:hover { transform:translateY(-3px); box-shadow:0 10px 40px rgba(0,180,255,0.45); }
.btn-primary:hover::before { opacity:1; }
.btn-outline {
  display: inline-flex; align-items: center; gap: 10px;
  background: transparent; color: var(--text); font-weight: 600; font-size: 0.9rem;
  padding: 14px 28px; border-radius: 50px;
  border: 1.5px solid rgba(0,180,255,0.25); cursor: pointer;
  transition: all 0.2s; font-family: var(--font-body);
}
.btn-outline:hover { border-color: var(--neon); color: var(--neon); background: rgba(0,180,255,0.06); transform: translateY(-2px); }

/* stats row */
.hero-stats {
  display: flex; gap: 40px; justify-content: center; flex-wrap: wrap;
  margin-top: 70px;
  animation: fadeUp 1s 0.4s ease both;
}
.stat-item { text-align: center; }
.stat-num {
  font-family: var(--font-display); font-weight: 900;
  font-size: clamp(1.8rem,3vw,2.6rem); letter-spacing: -1px;
  background: linear-gradient(135deg, var(--neon), var(--neon2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.stat-label { font-size: 0.75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }

/* scroll indicator */
.scroll-hint {
  position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  color: var(--muted); font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;
  animation: fadeUp 1s 0.6s ease both;
}
.scroll-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--neon); animation: scrollBounce 2s ease-in-out infinite; }
@keyframes scrollBounce { 0%,100%{transform:translateY(0);opacity:1;} 50%{transform:translateY(8px);opacity:0.3;} }

/* floating code chips */
.code-chip {
  position: absolute; font-family: var(--font-code); font-size: 0.72rem;
  background: rgba(0,180,255,0.06); border: 1px solid rgba(0,180,255,0.12);
  border-radius: 8px; padding: 6px 12px; color: var(--neon);
  pointer-events: none; z-index: 1;
  animation: chipFloat 8s ease-in-out infinite;
}
@keyframes chipFloat { 0%,100%{transform:translateY(0) rotate(-1deg);opacity:0.6;} 50%{transform:translateY(-20px) rotate(1deg);opacity:1;} }

/* ============================================================
   ABOUT CEO SECTION
============================================================ */
#sec-about { padding: clamp(60px,8vw,120px) clamp(24px,5vw,80px); }
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(40px,6vw,80px); align-items: center; max-width: 1100px; margin: 0 auto; }
.about-img-wrap { position: relative; display: flex; justify-content: center; }
.ceo-img-frame {
  position: relative; width: clamp(240px,30vw,320px); height: clamp(240px,30vw,320px);
  border-radius: 30px; overflow: hidden;
  border: 2px solid rgba(0,180,255,0.2);
  box-shadow: 0 0 60px rgba(0,180,255,0.15);
  transition: box-shadow 0.4s;
  cursor: pointer;
}
.ceo-img-frame:hover { box-shadow: 0 0 100px rgba(0,180,255,0.4), 0 0 40px rgba(120,80,255,0.3); }
.ceo-img-frame::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(0,180,255,0.1), rgba(120,80,255,0.1), transparent);
  opacity: 0; transition: opacity 0.3s;
}
.ceo-img-frame:hover::after { opacity: 1; }
.ceo-avatar {
  width: 100%; height: 100%;
  background: linear-gradient(135deg, #0c1a30, #1a0c30);
  display: flex; align-items: center; justify-content: center;
  font-size: clamp(5rem,10vw,8rem);
}
.ceo-ring {
  position: absolute; inset: -12px; border-radius: 40px;
  border: 2px solid rgba(0,180,255,0.15);
  animation: ringRotate 8s linear infinite;
}
.ceo-ring2 {
  position: absolute; inset: -24px; border-radius: 50px;
  border: 1px dashed rgba(120,80,255,0.1);
  animation: ringRotate 12s linear infinite reverse;
}
@keyframes ringRotate { to { transform: rotate(360deg); } }
.ceo-badge {
  position: absolute; bottom: -16px; right: -16px;
  background: linear-gradient(135deg, var(--gold), #ff8c00);
  border-radius: 14px; padding: 10px 16px;
  font-family: var(--font-display); font-size: 0.62rem; font-weight: 700;
  color: #1a0800; letter-spacing: 1px;
  box-shadow: 0 8px 24px rgba(240,165,0,0.4);
}
.about-content { }
.section-eyebrow { font-family: var(--font-code); font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--neon); margin-bottom: 12px; }
.section-title {
  font-family: var(--font-display); font-size: clamp(1.8rem,3vw,2.8rem);
  font-weight: 800; letter-spacing: -1.5px; line-height: 1.1; margin-bottom: 20px;
}
.section-title em { font-style: normal; background: linear-gradient(135deg, var(--neon), var(--neon2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.ceo-name { font-family: var(--font-display); font-size: clamp(1.4rem,2.5vw,2rem); font-weight: 800; letter-spacing: -0.5px; margin-bottom: 6px; color: var(--gold); }
.ceo-role { font-size: 0.85rem; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 24px; font-family: var(--font-code); }
.ceo-bio { color: var(--muted); line-height: 1.8; font-size: 0.95rem; margin-bottom: 28px; }
.ceo-bio strong { color: var(--text); }
.skill-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px; }
.skill-tag {
  background: rgba(0,180,255,0.08); border: 1px solid rgba(0,180,255,0.15);
  border-radius: 50px; padding: 5px 14px; font-size: 0.75rem; font-weight: 600;
  color: var(--neon); transition: all 0.2s; cursor: default;
}
.skill-tag:hover { background: rgba(0,180,255,0.15); transform: translateY(-1px); }
.skill-tag.purple { color: var(--neon2); border-color: rgba(120,80,255,0.2); background: rgba(120,80,255,0.08); }
.skill-tag.gold { color: var(--gold); border-color: rgba(240,165,0,0.2); background: rgba(240,165,0,0.06); }
.ceo-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
.ceo-stat { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; text-align: center; }
.ceo-stat-num { font-family: var(--font-display); font-weight: 800; font-size: 1.4rem; color: var(--neon); }
.ceo-stat-label { font-size: 0.7rem; color: var(--muted); margin-top: 4px; }

/* ============================================================
   PROJECTS SECTION
============================================================ */
#sec-projects { padding: clamp(60px,8vw,120px) clamp(24px,5vw,80px); background: linear-gradient(180deg, transparent 0%, rgba(120,80,255,0.03) 50%, transparent 100%); }
.section-header { text-align: center; margin-bottom: 56px; }
.projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px,1fr)); gap: 24px; max-width: 1200px; margin: 0 auto; }
.project-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 28px; position: relative;
  overflow: hidden; transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  cursor: pointer;
}
.project-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--neon), transparent);
  opacity: 0; transition: opacity 0.3s;
}
