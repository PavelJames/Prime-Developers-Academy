        ${LANG_DOTS[p.language]||'⬡'} ${p.language||'Code'}
      </div>
      <div class="project-name">${p.name}</div>
      <div class="project-desc">${p.description||'An innovative project by Prime Developers Academy.'}</div>
      <div class="project-meta">
        <div class="project-stars">⭐ ${p.stargazers_count||0} &nbsp; 🍴 ${p.forks_count||0}</div>
        <a class="project-btn" href="${p.html_url||'#'}" target="_blank" onclick="event.stopPropagation()">View →</a>
      </div>
    </div>`).join('');
  initReveal();
}

